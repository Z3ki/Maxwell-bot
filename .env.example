# =============================================================================
# Maxwell — .env template
# Copy to .env and fill in your own values. Everything with a default below
# works out of the box; only the required lines (marked REQUIRED) need values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required to start the bot
# -----------------------------------------------------------------------------
DISCORD_TOKEN=

# -----------------------------------------------------------------------------
# LLM provider (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Base URL of any OpenAI-compatible endpoint. The default targets a local
# Ollama; point it at Ollama Cloud, OpenRouter, LM Studio, vLLM, etc.
OLLAMA_BASE_URL=http://localhost:11434
# Bearer token if your endpoint requires one. Optional for local Ollama.
OLLAMA_API_KEY=
# Model name. The default is what the dev uses day-to-day; pick whatever
# your provider offers and supports the modalities you need.
OLLAMA_MODEL=gemma4:31b-cloud
# Separate model for the REM dreaming pass. Defaults to OLLAMA_MODEL.
OLLAMA_REM_MODEL=
# Max *output* tokens per completion (not the context window). 8192 is a
# sane default; raise it for long generations, lower it to save cost.
OLLAMA_MAX_TOKENS=8192
OLLAMA_TEMPERATURE=1.0
# Add OpenRouter-style reasoning=exclude on primary calls (true to save cost
# on reasoning models, false if your endpoint rejects the param).
OLLAMA_DISABLE_REASONING=true

# Optional secondary endpoint. Requests rotate primary→fallback→primary
# when this is set. Leave blank to disable.
OLLAMA_FALLBACK_BASE_URL=
OLLAMA_FALLBACK_API_KEY=
OLLAMA_FALLBACK_MODEL=
OLLAMA_FALLBACK_DISABLE_REASONING=true
# Total provider attempts per request (1 = no retries, 3 = primary+fallback+primary).
OLLAMA_RETRY_ATTEMPTS=3

# Optional catch-all bearer used as fallback when OLLAMA_API_KEY /
# AUTONOMY_API_KEY are empty. Useful for sharing a single key across
# services in a homelab.
OPENAI_COMPAT_API_KEY=

# Autonomy engine can run on a different endpoint from main chat. Any field
# left blank falls back to the matching OLLAMA_* value.
AUTONOMY_BASE_URL=
AUTONOMY_API_KEY=
AUTONOMY_MODEL=
AUTONOMY_DISABLE_REASONING=false

# -----------------------------------------------------------------------------
# Feature kill switches (default true — matches legacy behaviour)
# Set to false to skip registering the tool, importing the heavy dep, or
# auto-starting the background loop. Disabling a feature is the ONLY way
# to install Maxwell without paying for an API key it would otherwise need.
# -----------------------------------------------------------------------------
# Vision / multimodal INPUT (forwarding images, video frames, audio to the LLM)
ENABLE_IMAGE_INPUT=true            # already controlled via process_images in dashboard
ENABLE_VIDEO_INPUT=true            # ffmpeg frame extraction for video/* attachments
ENABLE_AUDIO_INPUT=false           # forward audio to "omni" audio-capable models

# Tool registration (LLM-facing)
ENABLE_IMAGE_GEN=true              # image_generator (Pollinations, free) + hd_image (NVIDIA, paid)
ENABLE_TTS=true                    # the `tts` tool (espeak local / riva / gtts)
ENABLE_EMAIL_TOOLS=true            # email_send / read_inbox / get_message / search (needs Postfix+Dovecot)
ENABLE_VC=true                     # voice chat (live listening) — needs discord-ext-voice-recv + libsodium
ENABLE_YOUTUBE=true                # `youtube` tool (needs yt-dlp; auto-flips false if binary missing)
ENABLE_WEB_SEARCH=true             # `web_search` tool (needs `ddgs` package)
ENABLE_FETCH_URL=true              # `fetch_url` tool
ENABLE_SUBAGENT=true               # `sub_agent` tool (needs `opencode` binary; auto-flips false if missing)
ENABLE_CREATE_SITE=true            # create_site / list_sites (needs MAXWELL_SITE_DIR writable)
ENABLE_AVATAR=true                 # change_avatar tool
ENABLE_SHELL=true                  # shell tool (host access — only enable if you trust the model)
ENABLE_TELEGRAM=true               # auto-start Telegram polling/webhook if TELEGRAM_TOKEN is set

# Disable the indirect-prompt-injection gate on shell/sub_agent. When false
# (default), a turn that read fetched URL content or web_search results
# requires an out-of-band `,confirm` from an admin before shell can run.
# When true, shell runs unconditionally. Only enable if you trust the
# model (single-user homelab install).
DISABLE_TAINT_GATE=false

# Background loops
ENABLE_REM=false                   # REM dreaming pass (see REM_* below)
ENABLE_AUTONOMY=false              # autonomy engine (see autonomy_* in dashboard / control)

# -----------------------------------------------------------------------------
# TTS engine selection (only relevant if ENABLE_TTS=true)
# -----------------------------------------------------------------------------
# local = espeak-ng on the host (no API key, default)
# riva  = NVIDIA Riva TTS (needs NVIDIA_API_KEY, TTS_RIVA_*)
# gtts  = Google Translate TTS (no API key, lower quality, requires outbound HTTPS)
# auto  = riva if NVIDIA_API_KEY is set, else local
TTS_ENGINE=auto

TTS_RIVA_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
TTS_RIVA_VOICE=Magpie-Multilingual.EN-US.Jason.Angry
TTS_RIVA_LANGUAGE=en-US

# -----------------------------------------------------------------------------
# Image generation
# -----------------------------------------------------------------------------
# image_generator (pollinations + nvidia flux) needs nothing by default.
POLLINATIONS_MODEL=flux
# hd_image (higher quality) needs an NVIDIA NIM key.
NVIDIA_API_KEY=
NVIDIA_IMAGE_URL=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev
# Optional GPT-Image-1 compatible endpoint.
GPT_IMAGE_URL=
GPT_IMAGE_API_KEY=

# -----------------------------------------------------------------------------
# Memory, REM, autonomy (REM_ENABLED above; detailed knobs below)
# -----------------------------------------------------------------------------
DATA_DIR=data
LOGS_DIR=logs
LOG_LEVEL=info
MEMORY_MESSAGE_LIMIT=2000

REM_INTERVAL_SECONDS=600
REM_MAX_TURNS=3
REM_EVENT_BUFFER_MAX=500
REM_RUN_HISTORY=50

# -----------------------------------------------------------------------------
# Discord UX
# -----------------------------------------------------------------------------
# Cooldown for change_avatar tool, in seconds. Default 0 (no local cooldown;
# Discord's own API rate limit still applies, you'll just get a 429 instead
# of a friendly error). Set to 1800 for the old 30-min behaviour.
AVATAR_COOLDOWN_SECONDS=0

# Live tool progress messages. When true, the bot posts one short status
# message per non-terminal tool batch ("shell: checking disk"), edits it
# in place as tools run, and deletes it when the batch ends.
MAXWELL_PROGRESS_MESSAGES=false

# Custom streaming tool-call protocol. Some providers (notably Ollama Cloud's
# minimax-m3) don't stream tool_calls incrementally with native tools= — they
# deliver the whole {name, arguments} block in one final delta, so the bot's
# progress message stays silent for the full generation. When this is on, the
# bot asks the model to emit the tool call as a bare JSON object on its own
# line and parses it from the text stream as it streams. Tool name lands in
# the progress UI at ~12% of stream time vs ~88% for native. Default off.
MAXWELL_CUSTOM_TOOL_CALLS=false

# -----------------------------------------------------------------------------
# Admin API / dashboard
# -----------------------------------------------------------------------------
MAXWELL_ADMIN_USER=admin
# WARNING: Set this to a real password. An empty value means the API refuses
# every request with 503.
MAXWELL_ADMIN_PASSWORD=
# Comma-separated Discord user IDs for bot owners (admin commands).
MAXWELL_OWNER_IDS=
# Where the bot looks for its own .env and the site/ directory. Defaults
# point at the repo root so a fresh `git clone` + `cp .env.example .env`
# works without editing paths. Override these for a /opt/maxwell install.
MAXWELL_APP_ROOT=
MAXWELL_ENV_FILE=
MAXWELL_SITE_DIR=
# Public URL where generated sites are served. Used for absolute links in
# the dashboard and Discord embeds. Leave blank to use localhost.
MAXWELL_PUBLIC_BASE_URL=
MAXWELL_CORS_ORIGIN=
MAXWELL_API_HOST=127.0.0.1
MAXWELL_API_PORT=8765

# Discord OAuth on the dashboard. Leave both empty to keep Basic auth only.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_ALLOWED_USER_IDS=

# Trust the X-Forwarded-For header from the reverse proxy. Enable ONLY behind
# Caddy/nginx so the dashboard records real client IPs, not 127.0.0.1.
MAXWELL_TRUST_PROXY=false

# -----------------------------------------------------------------------------
# Shell tool (host access)
# -----------------------------------------------------------------------------
# Daily tool-call token budget (0 = no limit). Shell is a security boundary;
# keep MAXWELL_SHELL_FULL_HOST=false unless you really want shell=host shell.
MAXWELL_SHELL_MAX_OUTPUT=100000
MAXWELL_SHELL_MAX_COMMAND_LENGTH=65536
MAXWELL_SHELL_TIMEOUT=600
MAXWELL_SHELL_FULL_HOST=false

# Host-level coding agent escape hatch. Keep false unless you really mean it.
MAXWELL_ENABLE_KILO_TOOL=false

# -----------------------------------------------------------------------------
# Email (Postfix + Dovecot on localhost by default)
# -----------------------------------------------------------------------------
# All defaults assume a local MTA / IMAPS server on 127.0.0.1. If you want
# to point the bot at a remote server (e.g. Mailgun's SMTP relay), override
# the host/port and put a real password below. Set ENABLE_EMAIL_TOOLS=false
# to skip the four email tools entirely.
MAXWELL_SMTP_HOST=127.0.0.1
MAXWELL_SMTP_PORT=25
MAXWELL_IMAP_HOST=127.0.0.1
MAXWELL_IMAP_PORT=993
MAXWELL_EMAIL_USER=
MAXWELL_EMAIL_PASSWORD=
MAXWELL_EMAIL_FROM=
MAXWELL_EMAIL_FROM_NAME=Maxwell

# -----------------------------------------------------------------------------
# OpenCode sub-agent (only used if ENABLE_SUBAGENT=true)
# -----------------------------------------------------------------------------
OPENCODE_SUBAGENT_BASE_DIR=subagents
OPENCODE_SUBAGENT_MODEL=ollama-cloud/minimax-m3
OPENCODE_SUBAGENT_TIMEOUT_MINUTES=30
OPENCODE_SUBAGENT_DOCKER=true
OPENCODE_SUBAGENT_MEMORY=2g
OPENCODE_SUBAGENT_CPUS=1.0
# 'bridge' so the container can resolve DNS and reach the operator's LLM
# endpoint. Set to 'none' only if you expose the LLM via a sidecar or
# bake DNS into /etc/hosts.
OPENCODE_SUBAGENT_NETWORK=bridge
OPENCODE_BIN=opencode

# -----------------------------------------------------------------------------
# YouTube cookies (optional)
# -----------------------------------------------------------------------------
# Path to a Netscape-format cookies.txt for YouTube bot-check workarounds.
# Never commit this file.
YOUTUBE_COOKIES_FILE=
