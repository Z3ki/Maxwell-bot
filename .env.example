DISCORD_TOKEN=
TELEGRAM_TOKEN=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_REM_MODEL=
OLLAMA_MAX_TOKENS=200000
OLLAMA_TEMPERATURE=1.0
OLLAMA_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_FALLBACK_API_KEY=
OLLAMA_FALLBACK_MODEL=moonshotai/kimi-k2.6:free
OLLAMA_FALLBACK_DISABLE_REASONING=true
OLLAMA_RETRY_ATTEMPTS=3

# "Omni" audio model toggle.
# Default is OFF (no audio sent to LLM). Set to true to enable audio/voice input.
ENABLE_AUDIO_INPUT=false

POLLINATIONS_MODEL=flux
NVIDIA_API_KEY=
NVIDIA_IMAGE_URL=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev
TTS_RIVA_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
TTS_RIVA_VOICE=Magpie-Multilingual.EN-US.Jason.Angry
TTS_RIVA_LANGUAGE=en-US
GPT_IMAGE_URL=
GPT_IMAGE_API_KEY=

DATA_DIR=data
LOGS_DIR=logs
LOG_LEVEL=info
MEMORY_MESSAGE_LIMIT=30

# Cooldown for change_avatar tool, in seconds. Default 0 (no local cooldown;
# Discord's own API rate limit still applies, you'll just get a 429 instead
# of a friendly error). Set to 1800 for the old 30-min behavior.
AVATAR_COOLDOWN_SECONDS=0

# REM dreaming memory assimilation (opt-in)
REM_ENABLED=false
REM_INTERVAL_SECONDS=600
REM_MAX_TURNS=3
REM_EVENT_BUFFER_MAX=500
REM_RUN_HISTORY=50

MAXWELL_ADMIN_USER=admin
# WARNING: Change this password before deploying. A weak/known password
# means anyone who finds your API endpoint can control the bot.
MAXWELL_ADMIN_PASSWORD=
# Comma-separated Discord user IDs for bot owners (used for admin commands)
MAXWELL_OWNER_IDS=0000000000000000000,0000000000000000000
MAXWELL_APP_ROOT=/opt/maxwell
MAXWELL_ENV_FILE=/opt/maxwell/.env
MAXWELL_SITE_DIR=/var/www/maxwell/bot
MAXWELL_PUBLIC_BASE_URL=https://maxwell.example.com
MAXWELL_CORS_ORIGIN=https://maxwell.example.com
MAXWELL_API_HOST=127.0.0.1
MAXWELL_API_PORT=8765

# Host-level coding agent escape hatch. Keep false unless you really mean it.
MAXWELL_ENABLE_KILO_TOOL=false

MAXWELL_SHELL_MAX_OUTPUT=100000
MAXWELL_SHELL_MAX_COMMAND_LENGTH=65536
MAXWELL_SHELL_TIMEOUT=600
MAXWELL_SHELL_FULL_HOST=false

# Live tool progress messages. When true, the bot posts one short status
# message per non-terminal tool batch ("shell: checking disk"), edits it
# in place as tools run, and deletes it when the batch ends. The message
# is the model's own thought (the `reasoning` field) prefixed with the
# tool name in plain text — no emoji, no decoration. The message gets
# deleted automatically; the tool's actual streamed output and the
# final send_message reply are what remains in the channel. Default off.
MAXWELL_PROGRESS_MESSAGES=false

# OpenCode sub-agent configuration
OPENCODE_SUBAGENT_BASE_DIR=subagents
OPENCODE_SUBAGENT_MODEL=ollama-cloud/minimax-m3
OPENCODE_SUBAGENT_TIMEOUT_MINUTES=30
OPENCODE_SUBAGENT_DOCKER=true
OPENCODE_SUBAGENT_MEMORY=2g
OPENCODE_SUBAGENT_CPUS=1.0
# Default 'bridge' so the container can resolve DNS and reach the operator-
# configured LLM endpoint. Set to 'none' only if you expose the LLM via a
# sidecar, host gateway, or baked-in /etc/hosts entries; the container has
# zero DNS resolution otherwise and every provider call will fail.
OPENCODE_SUBAGENT_NETWORK=bridge
OPENCODE_BIN=opencode
OLLAMA_API_KEY=

# Local mail (maxwell@z3ki.dev) — bot talks to local Postfix + Dovecot.
# Postfix listens on 25 (submission + STARTTLS) and 587 is unused by us;
# Dovecot listens on 993 (IMAPS). The defaults below are the local server
# that the email_integration/ setup builds. Override only if you have a
# reason to point the bot at a different mail server.
MAXWELL_SMTP_HOST=127.0.0.1
MAXWELL_SMTP_PORT=25
MAXWELL_IMAP_HOST=127.0.0.1
MAXWELL_IMAP_PORT=993
# Username is the full email address (matches /etc/dovecot/users).
# Password is the same one you put in /etc/dovecot/users.
MAXWELL_EMAIL_USER=maxwell@z3ki.dev
MAXWELL_EMAIL_PASSWORD=CHANGE_ME
MAXWELL_EMAIL_FROM=maxwell@z3ki.dev
MAXWELL_EMAIL_FROM_NAME=Maxwell
